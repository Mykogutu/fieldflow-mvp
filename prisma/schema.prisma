generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String   @unique
  password  String?
  name      String
  role      Role     @default(TECHNICIAN)
  baseZone  String?
  isActive  Boolean  @default(true)
  jobs      Job[]    @relation("JobWorkers")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id             String    @id @default(cuid())
  jobNumber      String    @unique @default(cuid())
  clientName     String
  clientPhone    String
  description    String?
  jobType        String
  status         JobStatus @default(ASSIGNED)
  priority       Priority  @default(NORMAL)
  location       String?
  zone           String?
  scheduledDate  DateTime?
  quotedAmount   Float?
  finalAmount    Float?
  otpCode        String?
  otpExpiresAt   DateTime?
  postponeReason String?
  postponedAt    DateTime?
  isReassigned   Boolean   @default(false)
  completedAt    DateTime?
  verifiedAt     DateTime?
  lastActionAt   DateTime?

  workers       User[]         @relation("JobWorkers")
  invoice       Invoice?
  notifications Notification[]
  events        JobEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type      String
  note      String?
  createdAt DateTime @default(now())
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  jobId         String        @unique
  job           Job           @relation(fields: [jobId], references: [id])
  amount        Float
  status        InvoiceStatus @default(PENDING)
  items         Json?
  pdfUrl        String?
  clientName    String
  clientPhone   String
  workerName    String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Expense {
  id          String          @id @default(cuid())
  description String
  amount      Float
  category    ExpenseCategory
  jobId       String?
  date        DateTime        @default(now())
  receiptUrl  String?
  notes       String?
  createdAt   DateTime        @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id])
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string")
}

// MVP-STRATEGY §17 — Branded WhatsApp Without Forking the Codebase
//
// One codebase routes to many senders. Branding lives as data, not code.
// `workspaceId` is null in single-tenant deployments today; when the full
// Workspace model lands (§16.3), populate it with the workspace's id.
model WhatsAppSender {
  id               String       @id @default(cuid())
  workspaceId      String?                                 // null = default/global tenant
  phoneNumber      String       @unique                    // E.164, the inbound `To` lookup key
  twilioAccountSid String                                  // subaccount per tenant (or main account)
  twilioAuthToken  String                                  // store encrypted at rest
  wabaId           String?                                 // null for SHARED, set for MANAGED/BYO
  displayName      String                                  // e.g. "AquaTech Plumbing"
  profilePhotoUrl  String?                                 // pushed to Meta WABA profile
  brandingTier     BrandingTier @default(SHARED)
  status           SenderStatus @default(PENDING)
  isVerified       Boolean      @default(false)            // green-tick
  isDefault        Boolean      @default(false)            // primary fallback for unrouted msgs
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([workspaceId])
  @@index([status])
}

enum BrandingTier {
  SHARED      // FieldFlow's number, branded message footer
  MANAGED     // Dedicated number under FieldFlow's BSP
  BYO_WABA    // Tenant's own WhatsApp Business Account (Embedded Signup)
}

enum SenderStatus {
  PENDING
  APPROVED
  ACTIVE
  REJECTED
  SUSPENDED
}

enum Role {
  ADMIN
  TECHNICIAN
}

enum JobStatus {
  ASSIGNED
  IN_PROGRESS
  POSTPONED
  RESCHEDULED
  COMPLETED_PENDING_VERIFICATION
  VERIFIED
  CLOSED
  DECLINED
  ISSUE_REPORTED
  CANCELLED
}

enum Priority {
  EMERGENCY
  HIGH
  NORMAL
  LOW
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum ExpenseCategory {
  MATERIALS
  TRANSPORT
  FUEL
  TOOLS
  LABOR
  OTHER
}
