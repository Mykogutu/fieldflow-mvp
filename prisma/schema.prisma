generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// MVP-STRATEGY v2.0 §16.3 — Multi-tenant Workspace
//
// The Workspace is the tenant container. `workspaceId` is required on every
// scoped model — the data-isolation invariant. The first migration sprint
// added it as nullable; this sprint enforces NOT NULL after verifying zero
// null rows in production.
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model User {
  id          String   @id @default(cuid())
  workspaceId String
  email       String?  @unique
  phone       String   @unique
  password    String?
  name        String
  role        Role     @default(TECHNICIAN)
  baseZone    String?
  isActive    Boolean  @default(true)
  jobs        Job[]    @relation("JobWorkers")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, role])
}

model Job {
  id             String    @id @default(cuid())
  workspaceId    String
  jobNumber      String    @unique @default(cuid())
  clientName     String
  clientPhone    String
  description    String?
  jobType        String
  status         JobStatus @default(ASSIGNED)
  priority       Priority  @default(NORMAL)
  location       String?
  zone           String?
  scheduledDate  DateTime?
  quotedAmount   Float?
  finalAmount    Float?
  otpCode        String?
  otpExpiresAt   DateTime?
  postponeReason String?
  postponedAt    DateTime?
  isReassigned   Boolean   @default(false)
  completedAt    DateTime?
  verifiedAt     DateTime?
  lastActionAt   DateTime?

  workers       User[]         @relation("JobWorkers")
  invoice       Invoice?
  notifications Notification[]
  events        JobEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, scheduledDate])
}

model JobEvent {
  id          String   @id @default(cuid())
  workspaceId String
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type        String
  note        String?
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([jobId])
}

model Invoice {
  id            String        @id @default(cuid())
  workspaceId   String
  invoiceNumber String        @unique
  jobId         String        @unique
  job           Job           @relation(fields: [jobId], references: [id])
  amount        Float
  status        InvoiceStatus @default(PENDING)
  items         Json?
  pdfUrl        String?
  clientName    String
  clientPhone   String
  workerName    String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, status])
}

model Expense {
  id          String          @id @default(cuid())
  workspaceId String
  description String
  amount      Float
  category    ExpenseCategory
  jobId       String?
  date        DateTime        @default(now())
  receiptUrl  String?
  notes       String?
  createdAt   DateTime        @default(now())

  @@index([workspaceId])
  @@index([workspaceId, category])
  @@index([workspaceId, date])
}

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  link        String?
  jobId       String?
  job         Job?     @relation(fields: [jobId], references: [id])
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, isRead])
}

// Setting is the workspace-scoped key/value config store. `workspaceId` is
// required and uniqueness is composite — same key can repeat across
// workspaces. All call sites already filter by workspaceId.
model Setting {
  id          String @id @default(cuid())
  workspaceId String
  key         String
  value       String
  type        String @default("string")

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

// MVP-STRATEGY v2.0 §6 — The Asset Layer
//
// The single biggest schema generalization. An Asset is "the thing the job
// is being done on" — water tank, vehicle, fuel sensor, inverter, building.
// One model, configurable labels, no per-industry tables.
model Asset {
  id                  String    @id @default(cuid())
  workspaceId         String
  name                String                                  // "Mrs. Wanjiku's 5000L tank"
  assetType           String                                  // configurable per industry
  identifier          String?                                 // free-form per industry
  serialNumber        String?
  registrationNumber  String?                                 // e.g. "KDA 123A" for vehicles
  deviceNumber        String?                                 // for trackers, sensors
  simNumber           String?                                 // for connected devices
  clientName          String
  clientPhone         String?
  location            String?
  zone                String?
  installationDate    DateTime?
  warrantyExpiryDate  DateTime?
  lastServiceDate     DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, clientPhone])
  @@index([assetType])
}

// MVP-STRATEGY v2.0 §11 — Documents (template-based, not industry-specific)
//
// Generalizes Warranty / Job Card / Installation Report / Service Report /
// Fuel Calibration Report etc. into a single table. Invoice stays separate
// because it carries financial state.
model Document {
  id           String       @id @default(cuid())
  workspaceId  String
  jobId        String?
  type         DocumentType
  title        String?                                        // optional human-readable title
  pdfUrl       String?
  metadata     Json?                                          // type-specific fields
  generatedAt  DateTime     @default(now())

  @@index([workspaceId])
  @@index([jobId])
  @@index([type])
}

enum DocumentType {
  INVOICE
  JOB_CARD
  WARRANTY_CERTIFICATE
  INSTALLATION_REPORT
  SERVICE_REPORT
  FUEL_CALIBRATION_REPORT
  DEVICE_REPLACEMENT_REPORT
  CLIENT_CONFIRMATION_RECEIPT
  DELIVERY_NOTE
  COMPLIANCE_CERTIFICATE
  OTHER
}

// MVP-STRATEGY v2.0 §10 — Partner Strategy & Product Ownership
//
// Resellers / pilot clients / introducers get capped commissions and zero IP.
// Workspaces optionally carry a partnerId so revenue share can be calculated
// at billing time.
model Partner {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("RESELLER")              // RESELLER | PILOT_CLIENT | INTRODUCER
  commissionRate  Float     @default(0.20)                    // setup-fee share, decimal (0.20 = 20%)
  recurringRate   Float     @default(0.15)                    // monthly recurring share
  recurringMonths Int       @default(12)                      // commission expires
  isActive        Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive])
}

// MVP-STRATEGY §17 — Branded WhatsApp Without Forking the Codebase
//
// One codebase routes to many senders. Branding lives as data, not code.
model WhatsAppSender {
  id               String       @id @default(cuid())
  workspaceId      String
  phoneNumber      String       @unique                    // E.164, the inbound `To` lookup key
  twilioAccountSid String                                  // subaccount per tenant (or main account)
  twilioAuthToken  String                                  // store encrypted at rest
  wabaId           String?                                 // null for SHARED, set for MANAGED/BYO
  displayName      String                                  // e.g. "AquaTech Plumbing"
  profilePhotoUrl  String?                                 // pushed to Meta WABA profile
  brandingTier     BrandingTier @default(SHARED)
  status           SenderStatus @default(PENDING)
  isVerified       Boolean      @default(false)            // green-tick
  isDefault        Boolean      @default(false)            // primary fallback for unrouted msgs
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([workspaceId])
  @@index([status])
}

enum BrandingTier {
  SHARED      // FieldFlow's number, branded message footer
  MANAGED     // Dedicated number under FieldFlow's BSP
  BYO_WABA    // Tenant's own WhatsApp Business Account (Embedded Signup)
}

enum SenderStatus {
  PENDING
  APPROVED
  ACTIVE
  REJECTED
  SUSPENDED
}

enum Role {
  ADMIN
  TECHNICIAN
}

enum JobStatus {
  ASSIGNED
  IN_PROGRESS
  POSTPONED
  RESCHEDULED
  COMPLETED_PENDING_VERIFICATION
  VERIFIED
  CLOSED
  DECLINED
  ISSUE_REPORTED
  CANCELLED
}

enum Priority {
  EMERGENCY
  HIGH
  NORMAL
  LOW
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum ExpenseCategory {
  MATERIALS
  TRANSPORT
  FUEL
  TOOLS
  LABOR
  OTHER
}
